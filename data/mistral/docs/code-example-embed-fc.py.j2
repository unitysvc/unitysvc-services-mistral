import os
import requests

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
UNITYSVC_BASE_URL = os.environ.get("UNITYSVC_BASE_URL")

def get_embeddings(model_name, inputs):
    """
    Returns embeddings from the Mistral API.
    model_name: str
    inputs: list[str]
    """
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {UNITYSVC_API_KEY}"
    }

    payload = {
        "model": model_name,
        "input": inputs
    }

    response = requests.post(UNITYSVC_BASE_URL, json=payload, headers=headers)
    response.raise_for_status()
    return response.json()


# Example usage:
if __name__ == "__main__":
    result = get_embeddings(
        "{{offering.name}}",
        ["Embed this sentence.", "As well as this one."]
    )
    print(result)
