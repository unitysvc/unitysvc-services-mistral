import os
import requests

API_KEY = os.getenv("API_KEY")
BASE_URL = "https://api.mistral.ai/v1/audio/transcriptions"

def transcribe_audio(model_name, file_url):
    """
    Sends an audio URL to Mistral for transcription.
    model_name: str
    file_url: str (public URL to audio file)
    """
    headers = {
        "x-api-key": API_KEY
    }

    files = {
        "file_url": (None, file_url),
        "model": (None, model_name)
    }

    response = requests.post(BASE_URL, headers=headers, files=files)
    response.raise_for_status()
    return response.json()

# Example usage:
if __name__ == "__main__":
    result = transcribe_audio(
        "{{offering.name}}",
        "https://docs.mistral.ai/audio/obama.mp3"
    )
    print(result)
