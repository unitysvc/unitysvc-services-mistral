const apiKey = process.env.UNITYSVC_API_KEY;

const response = await fetch("https://api.mistral.ai/v1/embeddings", {
  method: "POST",
  headers: {
    "Content-Type": "application/json",
    Authorization: `Bearer ${apiKey}`,
  },
  body: JSON.stringify({
    model: "{{offering.name}}",
    input: [
      "Embed this sentence.",
      "As well as this one."
    ]
  })
});

const data = await response.json();
console.log(data);
