import os
import json
import requests

# Config
UNITYSVC_API_KEY = os.environ.get("UNITYSVC_API_KEY")
API_ENDPOINT = os.environ.get("base_url")
MODEL = "{{offering.name}}"

headers = {
    "Authorization": f"Bearer {UNITYSVC_API_KEY}",
    "Content-Type": "application/json"
}

# Example local function
def echo_message(message):
    return f"Echo: {message}"

# Request payload
data = {
    "model": MODEL,
    "messages": [
        {"role": "system", "content": "You are a helpful assistant."},
        {"role": "user", "content": "This is a test"}
    ],
    "tools": [
        {
            "type": "function",
            "function": {
                "name": "echo_message",
                "description": "Echoes back the given message",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "message": {
                            "type": "string",
                            "description": "The message to echo"
                        }
                    },
                    "required": ["message"]
                }
            }
        }
    ],
    "tool_choice": "auto"
}

# Send request
response = requests.post(f"{API_ENDPOINT}", headers=headers, json=data)

if response.status_code != 200:
    print(f"Error {response.status_code}: {response.text}")
    exit()

completion = response.json()
message = completion["choices"][0]["message"]

# Handle tool calls
if "tool_calls" in message and message["tool_calls"]:
    for tool_call in message["tool_calls"]:
        function_name = tool_call["function"]["name"]
        function_args = json.loads(tool_call["function"]["arguments"])

        if function_name == "echo_message":
            result = echo_message(function_args["message"])
            print(result)
else:
    # Print model text output if no function call
    print(message.get("content", "⚠️ No content returned from model."))
