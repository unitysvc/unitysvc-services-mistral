const apiKey = process.env.UNITYSVC_API_KEY;
const ENDPOINT = process.env.SERVICE_BASE_URL;

const form = new FormData();
form.append("file_url", "https://docs.mistral.ai/audio/obama.mp3");
form.append("model", "{{offering.name}}");

const response = await fetch(`${ENDPOINT}`, {
  method: "POST",
  headers: {
    "x-api-key": apiKey,
    // ❗ DON'T set Content-Type — fetch does this automatically for multipart
  },
  body: form
});

const data = await response.json();
console.log(data);
